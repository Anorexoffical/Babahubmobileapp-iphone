# Server environment example
# Copy to .env.development for local dev and .env.production on the server

# App
PORT=3001

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/Babhub

# CORS
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173,https://account.babahub.co

# PayFast
PAYFAST_MERCHANT_ID=your_merchant_id
PAYFAST_MERCHANT_KEY=your_merchant_key
PAYFAST_PASSPHRASE=your_passphrase
PAYFAST_RETURN_URL=https://account.babahub.co/payment/payfast/success
PAYFAST_CANCEL_URL=https://account.babahub.co/payment/payfast/cancel
PAYFAST_NOTIFY_URL=https://account.babahub.co/payment/payfast/notifyurl
# true for sandbox, false for live
PAYFAST_SANDBOX=true
